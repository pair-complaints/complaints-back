<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <!-- Общие настройки для всех проверок -->
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Проверка длины файла -->
    <module name="FileLength">
        <property name="max" value="2000"/>
    </module>

    <!-- Проверка максимальной длины строки -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package|^import"/>
    </module>

    <!-- Основное дерево Java-кода -->
    <module name="TreeWalker">
        <!-- Имена пакетов: только нижний регистр и точки -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- Имена типов: PascalCase -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Имена полей: camelCase -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Имена констант: UPPER_SNAKE_CASE -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9_]*$"/>
        </module>

        <!-- Не использовать wildcard-импорты -->
        <module name="AvoidStarImport"/>

        <!-- Сортировка и группировка import -->
        <module name="RedundantImport"/>
        <module name="UnusedImports"/>

        <!-- Нет пустых блоков {} -->
        <module name="EmptyBlock"/>

        <!-- Отступы: 4 пробела -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="tabWidth" value="4"/>
        </module>

        <!-- Максимальная длина метода -->
        <module name="MethodLength">
            <property name="max" value="80"/>
        </module>

        <!-- Максимальное количество параметров -->
        <module name="ParameterNumber">
            <property name="max" value="5"/>
        </module>

        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="tokens" value="METHOD_DEF, ANNOTATION_FIELD_DEF, COMPACT_CTOR_DEF"/>
        </module>
    </module>
</module>
